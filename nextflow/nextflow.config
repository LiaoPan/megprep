// nextflow.config

// ------------------------------
// Global Parameters Configuration
// ------------------------------
params {
    dataset_dir = "/data/liaopan/datasets/SMN4Lang_single2"
    preproc_dir = "/data/liaopan/datasets/SMN4Lang_single2/preprocessed"          // Output results directory
    output_dir = "/data/liaopan/datasets/SMN4Lang_single2/test_nx" // nextflow logs directory
    
    code_dir = "/data/liaopan/megprep/megprep"   // all codes for preprocessing.

    // Pipeline mode: report | anatomy | all | meg_all | meg_artifacts | meg_ica | meg_epochs
    // Modifiers: skip_ica, with_anatomy (see meg_anat_pipeline_for_docker.nf)
    steps = 'meg_all'
    error_mode = 'lenient' // lenient: retry/ignore subject-level failures; strict: stop on first failure
    cohort = false
    cohort_max_parallel = 2
    cohort_child_pipeline_file = ''
    cohort_child_config = ''
    cohort_t1_root = ''

    is_bids = true  // Whether the data is in BIDS format
    meg_visualize = true
    anatomy_preprocess_method = "freesurfer" // "freesurfer" or "deepprep"

    osl_random_seed = 2025
    ICA_random_seed = 2025


    // MRI Parameters
    anatomy_preprocess_method = "freesurfer" // "freesurfer" or "deepprep"
    anatomy_select_tag = "" //"_run-02_T1w" // defalut:"", <subject_id>+<anatomy_tag> to select multiple runs T1.

    // MRI Import datasets
    mri_import_config = """
        # Filter out specific anatomy, only bids support.
        subject_id: '01' # str or null
        session_id: null # str or null
        task: null
        run_id: null
    """

    //freesurfer method
    t1_dir = dataset_dir // "/data/liaopan/datasets/Holmes_cn/T1" // dataset_dir      // T1 image directory
    t1_input_type = "nifti"                      // 'dicom' or 'nifti'

    fs_subjects_dir = "/data/liaopan/datasets/smn4lang_single2_smri"
    //fs_subjects_dir = "/data/liaopan/datasets/Holmes_cn/Holmes_cn_smri"
    freesurfer_home = "/data/liaopan/toolbox/freesurfer/7.4.1-1"

    //deepprep method
    deepprep_device = "cpu"
    t1_bids_dir = "/data/liaopan/datasets/Holmes_cn/T1_bids/"
    fs_license = "/data/liaopan/megprep/megprep/tools/DeepPrep/license.txt"

    //[fixed params]
    //fs_subjects_dir = "/smri" // FREESURFER SUBJECTS_DIR in Container[fixed]
    freesurfer_home = "/opt/freesurfer/7.4.1-1"


    // MEG import datasets
    dataset_format = 'auto'       // 'auto','bids' or 'raw'
    file_suffix = '.fif'          // only for raw datasets. Drop other .fif (phantom, etc.) via raw_exclude_keywords in meg_import_config.

    // MEG import datasets
    meg_import_config = """
        # BIDS only: filter subjects / sessions / tasks / runs.
        subject_id:
            - '01' # str or null
        session_id: null
        run_id: null
        task:
            - RDR

        # Raw datasets only: exclude .fif files whose basename contains any substring (case-insensitive).
        # Example: phantom, emptyroom, audiovisual (non-MEG runs that still use .fif).
        # raw_exclude_keywords:
        #     - phantom
        #     - emptyroom
    """

    // BEM model parameters
    bem_config = """
        ico: 4
        conductivity:
            - 0.3
    """

    // MEG Preprocessing Parameters
    preproc_config = """
        preproc:

        # Optional tSSS / MaxFilter step. Enable this for Elekta/MEGIN datasets
        # that need SSS/tSSS, and keep it before filtering/resampling.
        # - maxwell_filter:
        #     calibration: /path/to/sss_cal.dat
        #     cross_talk: /path/to/ct_sparse.fif
        #     st_duration: 10.0
        #     st_correlation: 0.98

        - filter: {l_freq: 0.5, h_freq: 125, method: iir, iir_params: {order: 5, ftype: butter}}
        - notch_filter: {freqs: 50 100}
        - resample: {sfreq: 250}
    """

    // MEG Artifacts Detection Parameters
    artifact_config = """
        find_bad_channels:
            pyprep:
                deviation:
                    deviation_threshold: 5.0
                snr: {}
                nan_flat: {}
                # hfnoise:
                #     HF_zscore_threshold: 5.0
              # ransac: # very slow
                #     n_samples: 50
                #     sample_prop: 0.25
                #     corr_thresh: 0.75
                #     frac_bad: 0.4
                #     corr_window_secs: 5.0
                #     channel_wise: true
                #     max_chunk_size: null
                # correlation:
                #     correlation_secs: 1.0
                #     correlation_threshold: 0.4
                #     frac_bad: 0.01
            psd:
                std_multiplier: 6
            osl:
                ref_meg: auto
                significance_level: 0.05
            mne:
                find_bad_channels_lof:
                    n_neighbors: 20
                    picks: mag
                    metric: euclidean
                    threshold: 1.5

        find_bad_segments:
            osl:
                segment_len: 1000 # detect_badsegments
            mne:
                annotate_muscle_zscore:
                    ch_type: mag
                    threshold: 12
                #annotate_amplitude:
                #    picks: meg
                # annotate_break:
                #     min_break_duration: 15.0
                #     t_start_after_previous: 5.0
                #     t_stop_before_next: 5.0
        interpolate_bads: false # true or false | interpolate bad channels with raw.interpolate_bads(reset_bads=True), save the updated bad channel list, and overwrite the preprocessed raw file.
        artifact_images_enabled: true
        meg_vendor: 'elekta' # 'ctf', 'elekta', '4d', 'kit', 'opm', ''
    """


    // MEG ICA Parameters
    num_IC = 60 // 0.99999
    ica_compute_explained_variance = false // true computes per-component explained variance; slower and optional
    ICA_output_dir = "ica_report" // relative path based on preproc dir [fixed_params]

    // MEG ICA Label Parameters
    ic_label_config = """
        # detect artifact ICs
        ic_ecg: true
        ic_eog: true
        ic_outlier: false # detect artifact ICs by rules.

        # algorithm settings
        ica_label: true # mne-ica_label algorithm: megnet
        mne_algorithm: true
        rules_algorithm: true

        # mne-algorithm
        find_bads_eog:
            ch_name: null # or the ch_name of EOG.
            threshold: auto
            l_freq: 1
            h_freq: 10
            start: null
            stop: null
            measure: zscore

        find_bads_ecg:
            ch_name: null # or the ch_name of ECG.
            threshold: auto
            method: ctps
            l_freq: 8
            h_freq: 16
            measure: zscore

        find_bads_muscle:
            threshold: 0.5
            start: null
            stop: null
            l_freq: 7
            h_freq: 45

       # rule-algorithm
        ICA_classify:
            meg_vendor: auto # auto, neuromag (or elekta), ctf, 4d, kit, quanmag_opm, quspin_opm
            meg_vendor_by_dataset: {} # optional mapping, e.g. {OPM-Artifacts: opm, Cam-CAN: neuromag}
            explained_var:
                threshold: 0.1
                ch_type: mag
            find_ecg_ics:
                time_segment: 10 # seconds
                ts_ecg_num_max: 20 # Maximum number of heartbeats expected in the chosen time segment
                l_freq: 0.1
                h_freq: 10
                peak_threshod_coef: 0.4 #Indicates the threshold of the number of ecg signal peak interval (unit: index). (peak_threshod = 0.4 * fs) | # for 1 seconds
                peak_std_threshold_coef: 0.05 #Standard deviation threshold of ecg signal peak interval (unit: index). (peak_std_threshold = peak_std_threshold_coef * fs) | # for 1 seconds
            find_abnormal_psd_ics:
                attention_low_freq: 0
                attention_high_freq: 150
                le_low_freq: 0
                le_high_freq: 12
                low_freq_energy_threshold: 0.8 # Threshold above which the component is flagged by low-frequency energy ratio
    """

    // MEG Epochs Parameters
    epoch_output_dir = "epochs" // relative path based on preproc dir
    epoch_config = """
    task_type: 'task'   # or 'resting'

    resting:
        fixed_length_duration: 2.0

    event_source: 'find_events'  # 'event_file' or 'find_events'

    autoreject: false  # true or false| automatic global_rejection_threshold, get the `reject` params.
    # By default, epochs keep bad channels listed in epochs.info['bads'] without interpolation or dropping.
    interpolate_bads: false  # true or false | interpolate bad channels in epochs using epochs.interpolate_bads().
    drop_bad_channels: false  # true or false | drop channels listed in epochs.info['bads'] using epochs.drop_channels().

    #event_file：specific the event type of *_events.tsv | filter | the value of `null` means to get all events.
    event_file:
        trial_type: null
        #type: # you can change `trial_type` to `type` or other type related.
        #    word_onset_01: 1
        #    phoneme_onset_01: 2
        # trial_type:
        #    - word_onset_01
        #    - phoneme_onset_01

    # find events
    find_events:
        stim_channel: null
        shortest_event: 1
        min_duration: 0.0
    epochs:
        event_id: null
        tmin: -0.2
        tmax: 0.8
        reject_by_annotation: true
        picks: meg
        baseline: null
        reject:
            mag: 4e-12
        preload: true
        detrend: null
    """


    // MEG-MRI coregistraion Parameters
    trans_output_dir = "trans"
    core_config = """
    omit_head_shape_points: 1 # mm
    grow_hair: 0.0 #mm
    icp:
        n_iterations: 200
        lpa_weight: 1.0
        nasion_weight: 10.0
        rpa_weight: 1.0
        hsp_weight: 10.0
        eeg_weight: 0.0
        hpi_weight: 1.0
    finetune_icp:
        n_iterations: 200
        lpa_weight: 0.0
        nasion_weight: 0.0
        rpa_weight: 0.0
        hsp_weight: 10.0
        eeg_weight: 0.0
        hpi_weight: 0.0
    """

    // Covariance Parameters
    covar_output_dir = "covariance"
    covar_visualize = true // Whether to generate covariance graphs
    covar_type = "epochs" // raw or epochs
    raw_covariance_task_id = "emptr" // task name
    covar_config = """
        ##[raw] 1.Estimate noise covariance matrix from a continuous segment of raw data.
        compute_raw_covariance:
            tmin: 0
            tmax: null
            method: auto
            reject:
                mag: 4e-12  # T (magnetometers)
            reject_by_annotation: true
            rank: info

        ##[epochs] 2.Estimate noise covariance matrix from epochs.
        # find events
        events:
            stim_channel: null
            shortest_event: 1
            min_duration: 0.0

        # For baseline epochs
        epochs:
            event_id: null # baseline event id
            tmin: -0.2 # Start time (in seconds) for covariance calculation window
            tmax: 0.0 # End time (in seconds) for covariance calculation window
            picks: mag
            baseline: null
            preload: true
            detrend: null
            reject_by_annotation: true

        covariance:
            tmin: null  #Start time for baseline. If null start at first sample.
            tmax: null  # End time for baseline. If null end at last sample.
            rank: null  # Rank used for covariance calculation| meg: 90
    """

    // Forward Solution Parameters
    fwd_output_dir = "forward_solution" // [fixed_params]
    fwd_epoch_label = "wdonset"
    fwd_config = """
        surface: white # pial
        spacing: ico4
    """

    // Source Imaging Parameters
    src_output_dir = "source_recon" // [fixed_params]
    src_type = "epochs" // raw or epochs
    src_config = """
        source_methods:
            - dSPM

        data_type: meg  # mag
        spacing: ico4
        epoch_label: wdonset

        dSPM:
            inverse_operator:
                loose: auto
                depth: 0.8
                fixed: auto
                rank: info
                    #meg : 50
            apply_inverse:
                ##lambda2: 0.1111111111
                method: dSPM
                pick_ori: normal

        LCMV:
            n_rank: 50  # compute_covariance,meg's n_rank
            cov_tmin: 0.01
            cov_tmax: 0.4
            make_lcmv:
                reg: 0.05
                pick_ori: null
                rank:
                    meg : 50
                weight_norm: unit-noise-gain-invariant
"""

    // Static global HTML report QC thresholds
    bad_channel_threshold = 30        // Warn when detected bad channels exceed this count
    bad_segment_threshold = 50        // Warn when detected bad segments exceed this count
    coreg_mean_threshold = 5.0        // Warn when mean coregistration distance exceeds this value in mm
    coreg_max_threshold = 10.0        // Warn when max coregistration distance exceeds this value in mm
    epoch_reject_rate_threshold = 0.30 // Warn when rejected epochs exceed this fraction of estimated epochs
    static_task_log_mode = 'all-command-log'   // failed | all-command-log | none
}

// ------------------------------
// Common Configuration
// ------------------------------

// Define the working directory for Nextflow
workDir = "${params.output_dir}/work"

// Logging configuration
log {
    file = "${params.preproc_dir}/logs/nextflow.log" // Path to the Nextflow log file
    level = 'INFO'                                  // Logging level: TRACE, DEBUG, INFO, WARN, ERROR
}


report {
    overwrite = true
}

timeline {
    overwrite = true
}

trace {
    overwrite = true
}

workflow {
    failOnIgnore = false
}

// Default resource allocation for processes (can be overridden by profiles)
process {
    cpus = 2                      // Default CPU cores per task
    memory = '8 GB'               // Default memory per task

    // Default lenient mode keeps the cohort moving: retry resource-related exits,
    // then ignore subject-level failures. Use -profile strict to stop immediately.
    errorStrategy = { params.error_mode == 'strict' ? 'terminate' : (task.exitStatus in 137..140 ? 'retry' : 'ignore') }
    maxRetries = 2

    withName: import_MRI_dataset {
        errorStrategy = 'terminate'
        maxRetries = 0
    }

    withName: import_MEG_dataset {
        errorStrategy = 'terminate'
        maxRetries = 0
    }

    withName: generate_static_html_report {
        errorStrategy = 'terminate'
        maxRetries = 0
    }

    withName: meg_preproc_osl {
        errorStrategy = { params.error_mode == 'strict' ? 'terminate' : (task.exitStatus in 137..140 ? 'retry' : 'ignore') }
        maxRetries = 3
    }

    withName: run_ICA {
        errorStrategy = { params.error_mode == 'strict' ? 'terminate' : (task.exitStatus in 137..140 ? 'retry' : 'ignore') }
        maxRetries = 3
    }

    withName: coregistration {
        errorStrategy = { params.error_mode == 'strict' ? 'terminate' : (task.exitStatus in 137..140 || task.exitStatus == 1 ? 'retry' : 'ignore') }
        maxRetries = 6
    }

    withName: compute_covariance {
        errorStrategy = { params.error_mode == 'strict' ? 'terminate' : (task.exitStatus in 137..140 || task.exitStatus == 1 ? 'retry' : 'ignore') }
        maxRetries = 3
    }

    withName: source_imaging {
        errorStrategy = { params.error_mode == 'strict' ? 'terminate' : (task.exitStatus in 137..140 || task.exitStatus == 1 ? 'retry' : 'ignore') }
        maxRetries = 6
    }
}

profiles {
    lenient {
        params.error_mode = 'lenient'
        workflow {
            failOnIgnore = false
        }
    }

    strict {
        params.error_mode = 'strict'
        workflow {
            failOnIgnore = true
        }
    }
}
